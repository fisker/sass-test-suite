{
  "name": "sass-test-suite",
  "version": "0.0.3",
  "description": "Sass Parsing Test Suite.",
  "homepage": "https://github.com/fisker/sass-test-suite#readme",
  "bugs": {
    "url": "https://github.com/fisker/sass-test-suite/issues"
  },
  "repository": "fisker/sass-test-suite",
  "funding": "https://github.com/fisker/sass-test-suite?sponsor=1",
  "license": "MIT",
  "author": {
    "name": "fisker Cheung",
    "email": "lionkay@gmail.com",
    "url": "https://www.fiskercheung.com/"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./data/*": "./data/*.js",
    "./*": "./*"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "data/*"
  ],
  "scripts": {
    "clean": "run-p \"clean:*\"",
    "clean:dist": "del-cli dist",
    "dist": "run-p \"dist:*\"",
    "dist:npm": "release-it",
    "fix": "run-p --continue-on-error \"fix:*\"",
    "fix:eslint": "yarn lint:eslint --fix",
    "fix:markdown": "yarn lint:markdown --fix",
    "fix:package-json": "sort-package-json \"package.json\" \"packages/*/package.json\"",
    "fix:prettier": "prettier . --write",
    "lint": "run-p --continue-on-error \"lint:*\"",
    "lint:eslint": "eslint .",
    "lint:markdown": "markdownlint-cli2",
    "lint:package-json": "yarn run fix:package-json --check",
    "lint:prettier": "prettier . --check",
    "release": "run-s fix test dist",
    "test": "run-p test:js test:types",
    "test:js": "node --test",
    "test:types": "tsd",
    "test-coverage": "c8 yarn test",
    "update": "node ./scripts/update.js"
  },
  "c8": {
    "include": [
      "index.js"
    ],
    "reporter": [
      "lcov",
      "text"
    ]
  },
  "devDependencies": {
    "@fisker/eslint-config": "16.0.0",
    "@fisker/lint-staged-config": "4.0.0",
    "@fisker/markdownlint-cli2-config": "0.1.0",
    "@fisker/prettier-config": "6.0.0",
    "@fisker/release-it-config": "6.0.2",
    "adm-zip": "0.5.18",
    "c8": "11.0.0",
    "del-cli": "7.0.0",
    "eslint": "10.6.0",
    "markdownlint-cli2": "0.22.1",
    "node-hrx": "0.1.0",
    "npm-run-all2": "9.0.2",
    "outdent": "0.8.0",
    "prettier": "3.9.4",
    "release-it": "20.2.1",
    "sort-package-json": "4.0.0",
    "tsd": "0.33.0",
    "write-prettier-file": "3.0.3"
  },
  "packageManager": "yarn@4.17.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
